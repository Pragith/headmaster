HEADMASTER_PORT=41869
HEADMASTER_HOST=0.0.0.0
HEADMASTER_APP_NAME=Headmaster
HEADMASTER_PUBLIC_BASE_URL=https://headmaster.example.com
HEADMASTER_SESSION_SECRET=replace-with-a-long-random-secret
HEADMASTER_AUTH_ENABLED=true
HEADMASTER_AUTH_ISSUER=https://sso.example.com/realms/example
HEADMASTER_AUTH_CLIENT_ID=headmaster
HEADMASTER_AUTH_CLIENT_SECRET=replace-with-oidc-client-secret
HEADMASTER_AUTH_REDIRECT_URI=https://headmaster.example.com/auth/callback
HEADMASTER_AUTH_SCOPE=openid profile email
HEADMASTER_AUTH_ADMIN_GROUP=headscale-admins
HEADMASTER_AUTH_GROUPS_CLAIM=groups
HEADMASTER_AUTH_NAME_CLAIM=name
HEADMASTER_AUTH_EMAIL_CLAIM=email
KEYCLOAK_URL=https://sso.example.com
KEYCLOAK_REALM=example
KC_ADMIN_USER=admin
KC_ADMIN_PASSWORD=
HEADMASTER_BOOTSTRAP_ADMIN_USERNAMES=admin,ops-admin
HEADMASTER_HEADSCALE_EXEC_MODE=docker
HEADMASTER_HEADSCALE_DOCKER_BIN=docker
HEADMASTER_HEADSCALE_CONTAINER=headscale
HEADMASTER_HEADSCALE_BINARY=headscale
HEADMASTER_HEADSCALE_CONFIG=/etc/headscale/config.yaml
HEADMASTER_HEADSCALE_CONFIG_FILE=
HEADMASTER_HEADSCALE_PUBLIC_URL=https://headscale.example.com
HEADMASTER_AUDIT_LOG_PATH=/workspace/.data/audit.jsonl
HEADMASTER_READ_ONLY=false
